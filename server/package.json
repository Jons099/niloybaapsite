{
  "name": "clothing-store",
  "version": "1.0.0",
  "description": "Premium women's clothing eCommerce backend with PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/migrations/migrate.js",
    "migrate:down": "node src/migrations/migrate.js down",
    "seed": "node src/scripts/seed.js",
    "test-connection": "node src/scripts/test-connection.js",
    "setup": "npm run migrate && npm run seed"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "sharp": "^0.33.1",
    "redis": "^4.6.10"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}